#!/usr/bin/env bash
set -euo pipefail

usage() {
  echo "Usage: agentspace-import <bundle-path>" >&2
  exit 1
}

BUNDLE="${1:-}"
if [ -z "$BUNDLE" ]; then
  usage
fi

if [ ! -f "$BUNDLE" ]; then
  echo "Error: Bundle not found: $BUNDLE" >&2
  exit 1
fi

# Must be run from inside a git repo
if ! git rev-parse --git-dir >/dev/null 2>&1; then
  echo "Error: Not inside a git repository" >&2
  exit 1
fi

echo "=== Verifying bundle ==="
if ! git bundle verify "$BUNDLE"; then
  echo "Error: Bundle verification failed" >&2
  exit 1
fi
echo ""

echo "=== Bundle refs ==="
git bundle list-heads "$BUNDLE"
echo ""

echo "=== Fetching from bundle ==="
# Build refspecs from bundle heads so we don't rely on HEAD existing
refspecs=()
while read -r sha ref; do
  branch="${ref#refs/heads/}"
  if [ "$branch" != "$ref" ]; then
    refspecs+=("$ref:refs/remotes/bundle/$branch")
  fi
done < <(git bundle list-heads "$BUNDLE")

if [ ${#refspecs[@]} -eq 0 ]; then
  # Fallback: fetch everything the bundle offers
  git fetch "$BUNDLE"
else
  git fetch "$BUNDLE" "${refspecs[@]}"
fi
echo ""

echo "=== Changes overview ==="
while read -r sha ref; do
  branch="${ref#refs/heads/}"
  if [ "$branch" = "$ref" ]; then
    continue
  fi

  echo "--- $branch ($sha) ---"

  merge_base=$(git merge-base HEAD "$sha" 2>/dev/null || echo "")
  if [ -n "$merge_base" ]; then
    git log --oneline "$merge_base..$sha"
    echo ""
    git diff --stat "$merge_base..$sha"
  else
    echo "  (no common ancestor with HEAD, showing recent commits)"
    git log --oneline -20 "$sha"
  fi
  echo ""
done < <(git bundle list-heads "$BUNDLE")

echo "=== Next steps ==="
echo "Branches fetched to refs/remotes/bundle/*"
echo ""
echo "To merge a branch:"
echo "  git merge bundle/<branch>"
echo ""
echo "To cherry-pick specific commits:"
echo "  git cherry-pick <commit-sha>"

package vhostuser

import (
	"encoding/binary"
	"testing"
	"time"

	"golang.org/x/sys/unix"
)

func TestSetVringKickPreservesNonblockingStatus(t *testing.T) {
	qemuFD, err := unix.Eventfd(0, unix.EFD_CLOEXEC|unix.EFD_NONBLOCK)
	if err != nil {
		t.Fatal(err)
	}
	defer unix.Close(qemuFD)

	backendFD, err := unix.Dup(qemuFD)
	if err != nil {
		t.Fatal(err)
	}

	device := NewDevice(nil)
	defer device.Close()
	if err := device.SetVringKick(backendFD, 0); err != nil {
		t.Fatalf("SetVringKick: %v", err)
	}

	flags, err := unix.FcntlInt(uintptr(qemuFD), unix.F_GETFL, 0)
	if err != nil {
		t.Fatal(err)
	}
	if flags&unix.O_NONBLOCK == 0 {
		t.Fatal("SetVringKick cleared O_NONBLOCK on the driver's shared eventfd")
	}
}

func TestReadLoopWaitsForNonblockingKickUntilCancelled(t *testing.T) {
	fd, err := unix.Eventfd(0, unix.EFD_CLOEXEC|unix.EFD_NONBLOCK)
	if err != nil {
		t.Fatal(err)
	}
	defer unix.Close(fd)

	vq := &Virtq{
		KickFD: fd,
		control: &readerControl{
			cancel: make(chan struct{}),
			done:   make(chan struct{}),
		},
	}
	go vq.readLoop(nil)

	select {
	case <-vq.control.done:
		t.Fatal("readLoop exited while a nonblocking kick fd was idle")
	case <-time.After(20 * time.Millisecond):
	}

	close(vq.control.cancel)
	var wake [8]byte
	binary.LittleEndian.PutUint64(wake[:], 1)
	if _, err := unix.Write(fd, wake[:]); err != nil {
		t.Fatalf("wake readLoop: %v", err)
	}

	select {
	case <-vq.control.done:
	case <-time.After(time.Second):
		t.Fatal("readLoop did not exit after cancellation")
	}
}
